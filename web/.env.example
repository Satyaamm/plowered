# Plowered frontend environment.
#
# Copy to .env.local (gitignored) and edit. Next.js auto-loads .env.local,
# .env.development, .env in that order — no extra tooling needed.
#
# Variables prefixed NEXT_PUBLIC_ are inlined into the client bundle at build
# time; everything else is server-only.

# Backend the dev proxy forwards /api/* to.
PLOWERED_API_BASE=http://localhost:8080

# Bearer token sent on every API call. Pair with PLOWERED_AUTH_DEV_PRINCIPAL
# on the server side for password-free local dev.
NEXT_PUBLIC_PLOWERED_TOKEN=dev

# Branding (shown in <title> and the header).
NEXT_PUBLIC_APP_NAME=plowered
