# ─────────────────────────────────────────────────────────────────────────────
# Plowered server environment.
#
# Copy to .env (gitignored) and edit. The Go binary auto-loads .env at
# startup via internal/config; production deployments inject these via the
# orchestrator (k8s, Render, etc.) instead.
#
# Single source of truth: do not duplicate defaults in code, docker-compose,
# or CI configs — read from this file or override at runtime.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
PLOWERED_ENV=dev                          # dev | staging | production
PLOWERED_VERSION=dev                      # build version, also surfaced via /healthz
PLOWERED_SHUTDOWN_GRACE=10s

# Listeners
PLOWERED_GRPC_ADDR=:9090
PLOWERED_HTTP_ADDR=:8080

# Storage
PLOWERED_DATABASE_URL=postgres://plowered:plowered@localhost:5432/plowered?sslmode=disable
PLOWERED_TEST_DATABASE_URL=               # used by integration tests; leave blank to skip

# Auth (JWT)
PLOWERED_JWT_ISSUER=plowered
PLOWERED_JWT_AUDIENCE=plowered
PLOWERED_JWT_HS256_SECRET=                # symmetric secret — DEV ONLY
PLOWERED_JWT_RS256_PUB_KEY=               # PEM contents OR @/path/to/key.pem

# Local-dev escape hatch: refused when PLOWERED_ENV=production.
# JSON Principal — example below grants full tenant access without a real token.
# PLOWERED_AUTH_DEV_PRINCIPAL={"ID":"dev","Email":"dev@example.com","TenantID":"dev","Roles":["admin"]}
PLOWERED_AUTH_DEV_PRINCIPAL=

# Rate limiting (per tenant)
PLOWERED_RATE_LIMIT_PER_SECOND=50
PLOWERED_RATE_LIMIT_BURST=100

# CORS — comma-separated list, "*" allows all (dev only).
PLOWERED_CORS_ALLOWED_ORIGINS=*

# Postgres (used by docker-compose; mirrors PLOWERED_DATABASE_URL)
POSTGRES_USER=plowered
POSTGRES_PASSWORD=plowered
POSTGRES_DB=plowered
POSTGRES_PORT=5432

# Redis — Asynq queue + idempotency cache + rate-limit counters.
# Empty REDIS_URL falls back to the in-process queue (dev mode only).
PLOWERED_REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# NATS JetStream — durable event bus across services.
# Empty NATS_URL falls back to the in-process bus (dev mode only).
PLOWERED_NATS_URL=nats://localhost:4222
NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222

# Object storage (S3-compatible). Local default is MinIO; prod points at S3/GCS.
PLOWERED_S3_ENDPOINT=http://localhost:9000
PLOWERED_S3_REGION=us-east-1
PLOWERED_S3_BUCKET_LOGS=plowered-logs
PLOWERED_S3_BUCKET_AUDIT=plowered-audit
PLOWERED_S3_ACCESS_KEY=minioadmin
PLOWERED_S3_SECRET_KEY=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Quality runner (async).
PLOWERED_QUALITY_DEFAULT_TIMEOUT=5m
PLOWERED_QUALITY_MAX_TIMEOUT=60m
PLOWERED_QUALITY_DEFAULT_SAMPLE_PCT=1     # TABLESAMPLE percent for big tables
PLOWERED_QUALITY_MAX_CONCURRENCY_PER_SOURCE=3
PLOWERED_QUALITY_RESULT_TTL=24h

# Pipeline runner.
PLOWERED_PIPELINE_MAX_CONCURRENCY_PER_TENANT=10
PLOWERED_PIPELINE_HEARTBEAT=30s
PLOWERED_PIPELINE_REAPER_INTERVAL=1m
PLOWERED_PIPELINE_STUCK_AFTER=5m

# Auth + email
# Web origin used to build verification links inside outbound emails.
PLOWERED_WEB_BASE_URL=http://localhost:3000
# From: header on transactional email. Resend's `onboarding@resend.dev`
# works without domain verification; replace with your own domain in prod.
PLOWERED_EMAIL_FROM=Plowered <onboarding@resend.dev>
# Resend transactional-email API key. Empty = log emails to stdout (local dev).
PLOWERED_RESEND_API_KEY=
# Session cookie name (under which the login session id rides).
PLOWERED_SESSION_COOKIE=plowered_session
# Optional cookie hardening — set when serving over HTTPS in prod.
PLOWERED_SESSION_COOKIE_DOMAIN=
PLOWERED_SESSION_COOKIE_SECURE=0

# Secrets vault master key — base64-encoded 32 bytes (256-bit AES-GCM).
# REQUIRED in production. When empty in dev, the server auto-generates a
# key per process and warns; stored secrets won't survive a restart.
# Generate with:  openssl rand -base64 32
PLOWERED_SECRETS_MASTER_KEY=
