# ─────────────────────────────────────────────────────────────────────────────
# Plowered server environment.
#
# Copy to .env (gitignored) and edit. The Go binary auto-loads .env at
# startup via internal/config; production deployments inject these via the
# orchestrator (k8s, Render, etc.) instead.
#
# Single source of truth: do not duplicate defaults in code, docker-compose,
# or CI configs — read from this file or override at runtime.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
PLOWERED_ENV=dev                          # dev | staging | production
PLOWERED_VERSION=dev                      # build version, also surfaced via /healthz
PLOWERED_SHUTDOWN_GRACE=10s

# Listeners
PLOWERED_GRPC_ADDR=:9090
PLOWERED_HTTP_ADDR=:8080

# Storage
PLOWERED_DATABASE_URL=postgres://plowered:plowered@localhost:5432/plowered?sslmode=disable
PLOWERED_TEST_DATABASE_URL=               # used by integration tests; leave blank to skip

# Auth (JWT)
PLOWERED_JWT_ISSUER=plowered
PLOWERED_JWT_AUDIENCE=plowered
PLOWERED_JWT_HS256_SECRET=                # symmetric secret — DEV ONLY
PLOWERED_JWT_RS256_PUB_KEY=               # PEM contents OR @/path/to/key.pem

# Local-dev escape hatch: refused when PLOWERED_ENV=production.
# JSON Principal — example below grants full tenant access without a real token.
# PLOWERED_AUTH_DEV_PRINCIPAL={"ID":"dev","Email":"dev@example.com","TenantID":"dev","Roles":["admin"]}
PLOWERED_AUTH_DEV_PRINCIPAL=

# Rate limiting (per tenant)
PLOWERED_RATE_LIMIT_PER_SECOND=50
PLOWERED_RATE_LIMIT_BURST=100

# CORS — comma-separated list, "*" allows all (dev only).
PLOWERED_CORS_ALLOWED_ORIGINS=*

# Postgres (used by docker-compose; mirrors PLOWERED_DATABASE_URL)
POSTGRES_USER=plowered
POSTGRES_PASSWORD=plowered
POSTGRES_DB=plowered
POSTGRES_PORT=5432
